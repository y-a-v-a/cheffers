{
  "name": "cheffers-playground",
  "version": "0.2.0",
  "private": true,
  "description": "Browser playground for the Cheffers Chef interpreter",
  "type": "module",
  "scripts": {
    "build": "esbuild editor.js --bundle --format=esm --minify --external:./pkg/* --outfile=editor.bundle.js",
    "test": "node --test tests/ansi.test.mjs",
    "test:browser": "node tests/browser.test.mjs"
  },
  "devDependencies": {
    "codemirror": "^6.0.1",
    "esbuild": "^0.25.0",
    "http-server": "^14.1.1",
    "playwright": "1.56.1"
  }
}
